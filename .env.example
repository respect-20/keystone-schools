# Copy this file to .env.local and fill in your actual values

# API Configuration
NEXT_PUBLIC_API_URL=https://api.keystoneschools.co.zw

# School Information
NEXT_PUBLIC_SCHOOL_NAME=Keystone Schools
NEXT_PUBLIC_SCHOOL_EMAIL=info@keystoneschools.co.zw
NEXT_PUBLIC_SCHOOL_PHONE=+263 773 000 000
NEXT_PUBLIC_SCHOOL_ADDRESS=123 Education Boulevard, Harare, Zimbabwe

# Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

# Email Configuration (for form submissions)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Miscellaneous
NEXT_PUBLIC_SITE_URL=https://keystoneschools.co.zw
NODE_ENV=production
